<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Executive Resume | Creator</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <style>
        :root {
            --bg-color: #ffffff;
            --accent: #000000;
            --text-main: #1a1a1a;
            --text-muted: #666666;
            --border: #e5e5e5;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f4f7;
            margin: 0;
            padding: 40px 20px;
            color: var(--text-main);
        }

        /* Resume Page Container */
        .resume-page {
            width: 210mm;
            min-height: 297mm;
            margin: 0 auto;
            background: var(--bg-color);
            padding: 50px;
            box-sizing: border-box;
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        /* Controls (Floating UI) */
        .controls {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
        }

        .btn-download {
            background: var(--accent);
            color: white;
            border: none;
            padding: 12px 24px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 4px;
            transition: opacity 0.2s;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 12px;
        }

        .btn-download:hover { opacity: 0.8; }

        /* Resume Content Styling */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 30px;
            margin-bottom: 40px;
        }

        .name-title h1 {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            margin: 0;
            text-transform: uppercase;
        }

        .name-title p {
            font-size: 14px;
            letter-spacing: 3px;
            color: var(--text-muted);
            text-transform: uppercase;
            margin: 5px 0 0 0;
        }

        .profile-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            background: #eee;
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 240px;
            gap: 50px;
        }

        h2 {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 8px;
            margin-bottom: 20px;
        }

        .section { margin-bottom: 35px; }

        .entry { margin-bottom: 20px; }
        .entry-head { display: flex; justify-content: space-between; font-weight: 600; font-size: 14px; }
        .entry-sub { font-style: italic; color: var(--text-muted); font-size: 13px; margin-bottom: 8px; }
        
        ul { padding-left: 18px; margin: 0; }
        li { font-size: 13px; margin-bottom: 5px; color: #333; }

        .sidebar-item { margin-bottom: 25px; font-size: 13px; }
        .skill-pill {
            display: inline-block;
            background: #f0f0f0;
            padding: 4px 10px;
            margin: 0 4px 6px 0;
            border-radius: 2px;
            font-size: 11px;
        }

        /* Hide elements during PDF generation */
        .no-print { display: block; }
    </style>
</head>
<body>

    <div class="controls">
        <button class="btn-download" onclick="generatePDF()">Download PDF</button>
    </div>

    <div id="resume-content" class="resume-page">
        
        <header>
            <div class="name-title">
                <h1 contenteditable="true">Your Name</h1>
                <p contenteditable="true">Executive Professional Title</p>
            </div>
            <img src="https://via.placeholder.com/150" alt="Profile" class="profile-img">
        </header>

        <div class="grid">
            <div class="main">
                <section class="section">
                    <h2>Professional Profile</h2>
                    <p contenteditable="true" style="font-size: 14px;">
                        Brief, high-impact summary of your career. Focus on architectural precision, results, and premium delivery standards. Edit this text directly in your browser.
                    </p>
                </section>

                <section class="section">
                    <h2>Experience</h2>
                    <div class="entry">
                        <div class="entry-head">
                            <span contenteditable="true">Senior Product Creator</span>
                            <span contenteditable="true">2022 — Present</span>
                        </div>
                        <div class="entry-sub" contenteditable="true">Aethercore Interactive | Portfolio</div>
                        <ul>
                            <li contenteditable="true">Led development of high-end utility applications with minimalist UI.</li>
                            <li contenteditable="true">Optimized performance for 3D physics engines in mobile environments.</li>
                        </ul>
                    </div>

                    <div class="entry">
                        <div class="entry-head">
                            <span contenteditable="true">Systems Developer</span>
                            <span contenteditable="true">2019 — 2022</span>
                        </div>
                        <div class="entry-sub" contenteditable="true">Previous Global Tech Corp</div>
                        <ul>
                            <li contenteditable="true">Managed Git repositories for large-scale corporate deployments.</li>
                            <li contenteditable="true">Implemented architectural UI standards across web platforms.</li>
                        </ul>
                    </div>
                </section>
            </div>

            <div class="sidebar">
                <section class="sidebar-item">
                    <h2>Contact</h2>
                    <div contenteditable="true">email@example.com</div>
                    <div contenteditable="true">+1 234 567 890</div>
                    <div contenteditable="true">github.com/yourprofile</div>
                    <div contenteditable="true">Location: City, Country</div>
                </section>

                <section class="sidebar-item">
                    <h2>Expertise</h2>
                    <div class="skill-pill" contenteditable="true">UI/UX Design</div>
                    <div class="skill-pill" contenteditable="true">Architecture</div>
                    <div class="skill-pill" contenteditable="true">React/Node</div>
                    <div class="skill-pill" contenteditable="true">3D Engines</div>
                    <div class="skill-pill" contenteditable="true">Product Strategy</div>
                </section>
            </div>
        </div>
    </div>

    <script>
        function generatePDF() {
            const element = document.getElementById('resume-content');
            const opt = {
                margin:       0,
                filename:     'Executive_Resume.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            // New Promise-based usage:
            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>
</html>
